generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  ARCHIVED
  SPAM
}

enum AdminRole {
  SUPER_ADMIN
  SECURITY_ADMIN
  READ_ONLY
}

enum AdminStatus {
  ACTIVE
  INACTIVE
}

enum AuditEvent {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  SETTINGS_CHANGED
  CONTACT_UPDATED
  SYSTEM
  MFA_ENABLED
  MFA_DISABLED
  MFA_QR_GENERATED
  MFA_VERIFY_SUCCESS
  MFA_VERIFY_FAILED
  MFA_BACKUP_CODE_USED
  MFA_BACKUP_REGENERATED
  MFA_CHALLENGE_INVALID
  MFA_CHALLENGE_EXPIRED
  MFA_FAILURE_LOCKOUT
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

model ContactSubmission {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String
  company   String?
  service   String?
  message   String
  status        ContactStatus @default(NEW)
  internalNotes String?
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([email])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([isDeleted])
  @@index([deletedAt])
  @@map("contact_submissions")
}

model Admin {
  id                  String          @id @default(cuid())
  name                String
  email               String          @unique
  hashedPassword      String
  role                AdminRole       @default(READ_ONLY)
  status              AdminStatus     @default(ACTIVE)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  failedLoginAttempts Int             @default(0)
  lockedUntil         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  auditLogs           AuditLog[]
  sessions            Session[]
  mfaChallenges       MfaChallenge[]
  trustedDevices      TrustedDevice[]

  // MFA Fields
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?   // Encrypted secret
  twoFactorIv         String?   // Encryption IV
  twoFactorTag        String?   // Encryption Authentication Tag
  
  tempTwoFactorSecret String?   // Temporary encrypted secret during setup
  tempTwoFactorIv     String?   // Temporary setup IV
  tempTwoFactorTag    String?   // Temporary setup tag

  backupCodes         BackupCode[]

  @@index([status])
  @@index([role])
  @@index([deletedAt])
  @@map("admins")
}

model Session {
  id          String    @id @default(cuid())
  hashedToken String    @unique
  adminId     String
  admin       Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([adminId])
  @@index([expiresAt])
  @@map("sessions")
}

model MfaChallenge {
  id          String   @id @default(cuid())
  hashedToken String   @unique // SHA-256 hash of the 256-bit challenge token
  adminId     String
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
  @@index([adminId])
  @@map("mfa_challenges")
}

model TrustedDevice {
  id                String    @id @default(cuid())
  hashedDeviceToken String    @unique // SHA-256 hash of the 256-bit device token
  adminId           String
  admin             Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  deviceName        String?
  userAgent         String?
  ipAddress         String?
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([adminId])
  @@index([expiresAt])
  @@map("trusted_devices")
}

model BackupCode {
  id          String   @id @default(cuid())
  hashedCode  String   @unique // SHA-256 hash of the recovery code
  adminId     String
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@map("backup_codes")
}

model AuditLog {
  id        String        @id @default(cuid())
  event     AuditEvent
  actorName String?
  details   String
  ipAddress String?
  severity  AuditSeverity @default(INFO)
  metadata  Json?
  adminId   String?
  admin     Admin?        @relation(fields: [adminId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@index([createdAt])
  @@index([event])
  @@index([severity])
  @@map("audit_logs")
}

model SystemSetting {
  id                   String   @id @default("default")
  portalTitle          String   @default("XIFOZ Admin Portal")
  rateLimit            Int      @default(60)
  sessionTimeout       Int      @default(7)
  notificationsEnabled Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  @@map("system_settings")
}
