# ─────────────────────────────────────────
# XIFOZ Server — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# Database — PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/xifoz?schema=public"

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# Rate limiting (optional — defaults shown)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Authentication
BCRYPT_ROUNDS=12
JWT_ACCESS_SECRET="generate_a_cryptographically_secure_random_key_here"
JWT_REFRESH_SECRET="generate_a_cryptographically_secure_random_key_here"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
COOKIE_NAME="refreshToken"
COOKIE_SAME_SITE=lax
COOKIE_MAX_AGE_MS=604800000
COOKIE_PATH="/api/auth"

# MFA Encryption key (hex-encoded 32-byte key or a secure long passphrase)
MFA_ENCRYPTION_KEY="your_secure_hex_or_passphrase_here"

# Email notifications via Resend (https://resend.com)
# Obtain your API key from the Resend dashboard
RESEND_API_KEY="re_your_api_key_here"
SUPPORT_EMAIL=support@xifoz.com
