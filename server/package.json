{
  "name": "xifoz-server",
  "version": "1.0.0",
  "description": "XIFOZ API server",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
